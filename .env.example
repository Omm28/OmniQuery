# ─────────────────────────────────────────────────────────────────────────────
# .env.example
# Copy this file to `.env` and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider (Ollama) ─────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Search Provider (Tavily) ───────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...
SEARCH_MAX_RESULTS=5

# ── Server ─────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── GitHub OAuth ───────────────────────────────────────────────────────────────
# Create a free OAuth App at: https://github.com/settings/developers
# Authorization callback URL must be: http://localhost:8000/auth/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_a_strong_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Session (Starlette) ────────────────────────────────────────────────────────
# Defaults to JWT_SECRET_KEY if not set. Set separately for extra isolation.
# SESSION_SECRET_KEY=another_strong_secret
